
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Proveedores · Aromas y Más</title>

<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{margin:0;font-family:Arial,Helvetica,sans-serif;background:#f3efe9;color:#2b211b}
header{background:linear-gradient(180deg,#7b5a46,#5d4333);color:white;padding:16px 20px;display:flex;justify-content:space-between;align-items:center}
h1{margin:0;font-size:24px}
.volver{background:white;color:#5d4333;border:0;border-radius:999px;padding:10px 16px;font-weight:900}
.contenedor{padding:18px;max-width:900px;margin:auto}
.card{background:white;border-radius:24px;padding:20px;margin-bottom:18px;box-shadow:0 10px 24px rgba(0,0,0,.12)}
label{font-weight:900;margin-top:12px;display:block}
input,select,textarea{width:100%;padding:14px;border-radius:14px;border:1px solid #cfc7bf;font-size:16px;margin-top:6px}
textarea{min-height:80px}
.botones{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}
button{border:0;border-radius:16px;padding:14px 18px;font-size:16px;font-weight:900;color:white;background:#5d4333}
.guardar{background:#5ca33f}
.borrar{background:#c00000}
.proveedor{background:#fff;border-left:7px solid #8c674d}
.proveedor h3{margin:0 0 8px;color:#5d4333}
.dato{font-weight:700;margin:4px 0;color:#333}
.vacio{text-align:center;font-weight:900;color:#8c674d;padding:20px}
</style>
</head>

<body>

<header>
<h1>🚚 Proveedores</h1>
<button class="volver" onclick="location.href='index.html'">VOLVER</button>
</header>

<div class="contenedor">

<div class="card">
<h2>Nuevo proveedor</h2>

<label>Nombre</label>
<input id="nombre" placeholder="Nombre del proveedor">

<label>Teléfono</label>
<input id="telefono" placeholder="Teléfono">

<label>Email</label>
<input id="email" placeholder="Email">

<label>Dirección</label>
<input id="direccion" placeholder="Dirección">

<label>Forma de pago</label>
<select id="pago">
<option value="">Seleccionar</option>
<option>Contado</option>
<option>Banco</option>
<option>A cuenta</option>
<option>Transferencia</option>
<option>Otro</option>
</select>

<label>Observaciones</label>
<textarea id="observaciones" placeholder="Notas importantes del proveedor"></textarea>

<div class="botones">
<button class="guardar" onclick="guardarProveedor()">GUARDAR</button>
<button onclick="limpiarFormulario()">LIMPIAR</button>
</div>
</div>

<div class="card">
<h2>Listado de proveedores</h2>
<div id="lista"></div>
</div>

</div>

<script>
let editandoId = null;

function leerProveedores(){
return JSON.parse(localStorage.getItem("aromas_proveedores") || "[]");
}

function guardarProveedores(datos){
localStorage.setItem("aromas_proveedores", JSON.stringify(datos));
}

function guardarProveedor(){

const proveedor = {
id: editandoId || Date.now(),
nombre: document.getElementById("nombre").value.trim(),
telefono: document.getElementById("telefono").value.trim(),
email: document.getElementById("email").value.trim(),
direccion: document.getElementById("direccion").value.trim(),
pago: document.getElementById("pago").value,
observaciones: document.getElementById("observaciones").value.trim(),
fecha: new Date().toLocaleString("es-ES")
};

if(!proveedor.nombre){
alert("Pon el nombre del proveedor.");
return;
}

let datos = leerProveedores();

if(editandoId){
datos = datos.map(p => p.id === editandoId ? proveedor : p);
}else{
datos.push(proveedor);
}

guardarProveedores(datos);
limpiarFormulario();
pintarProveedores();
}

function editarProveedor(id){

const p = leerProveedores().find(x => x.id === id);
if(!p) return;

editandoId = id;

document.getElementById("nombre").value = p.nombre || "";
document.getElementById("telefono").value = p.telefono || "";
document.getElementById("email").value = p.email || "";
document.getElementById("direccion").value = p.direccion || "";
document.getElementById("pago").value = p.pago || "";
document.getElementById("observaciones").value = p.observaciones || "";

window.scrollTo({top:0,behavior:"smooth"});
}

function borrarProveedor(id){

if(!confirm("¿Borrar este proveedor?")) return;

const datos = leerProveedores().filter(p => p.id !== id);
guardarProveedores(datos);
pintarProveedores();
}

function limpiarFormulario(){

editandoId = null;

document.getElementById("nombre").value = "";
document.getElementById("telefono").value = "";
document.getElementById("email").value = "";
document.getElementById("direccion").value = "";
document.getElementById("pago").value = "";
document.getElementById("observaciones").value = "";
}

function pintarProveedores(){

const lista = document.getElementById("lista");
const datos = leerProveedores();

if(datos.length === 0){
lista.innerHTML = "<div class='vacio'>No hay proveedores todavía.</div>";
return;
}

lista.innerHTML = datos.map(p => `
<div class="card proveedor">
<h3>${p.nombre}</h3>
<div class="dato">☎️ ${p.telefono || "Sin teléfono"}</div>
<div class="dato">✉️ ${p.email || "Sin email"}</div>
<div class="dato">📍 ${p.direccion || "Sin dirección"}</div>
<div class="dato">💳 ${p.pago || "Sin forma de pago"}</div>
<div class="dato">📝 ${p.observaciones || "Sin observaciones"}</div>
<div class="dato">📅 ${p.fecha || ""}</div>
<div class="botones">
<button onclick="editarProveedor(${p.id})">EDITAR</button>
<button class="borrar" onclick="borrarProveedor(${p.id})">BORRAR</button>
</div>
</div>
`).join("");
}

pintarProveedores();
</script>

</body>
</html>
